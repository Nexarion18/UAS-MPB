<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_SatglowWMS_AsIs_Inbound" targetNamespace="http://satglow.com/wms/asis/inbound" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <collaboration id="Collab_Inbound_AsIs">
    <participant id="Pool_Vendor" name="Vendor" processRef="Process_Vendor" />
    <participant id="Pool_Satglow" name="Internal Satglow" processRef="Process_Satglow" />
    <messageFlow id="MF_01" name="Surat Jalan &#38; Barang Fisik" sourceRef="Task_Vendor_KirimBarang" targetRef="Task_SG_TerimaBarang" />
    <textAnnotation id="Annotation_01">
      <text>Penyimpanan acak tanpa pemisahan batch / expired date</text>
    </textAnnotation>
    <association id="Assoc_01" associationDirection="None" sourceRef="Task_SG_SimpanRak" targetRef="Annotation_01" />
  </collaboration>
  <process id="Process_Vendor" name="Vendor" isExecutable="false">
    <startEvent id="Start_Vendor" name="Perlu mengirimkan barang ke gudang Satglow">
      <outgoing>SF_V01</outgoing>
    </startEvent>
    <endEvent id="End_Vendor" name="Barang &#38; Surat Jalan terkirim">
      <incoming>SF_V02</incoming>
    </endEvent>
    <sequenceFlow id="SF_V01" sourceRef="Start_Vendor" targetRef="Task_Vendor_KirimBarang" />
    <sequenceFlow id="SF_V02" sourceRef="Task_Vendor_KirimBarang" targetRef="End_Vendor" />
    <userTask id="Task_Vendor_KirimBarang" name="Mengirimkan Surat Jalan &#38; Barang Fisik&#10;ke Gudang">
      <incoming>SF_V01</incoming>
      <outgoing>SF_V02</outgoing>
    </userTask>
  </process>
  <process id="Process_Satglow" name="Internal Satglow" isExecutable="false">
    <laneSet id="LaneSet_Satglow">
      <lane id="Lane_StaffAdmin" name="Staff Admin">
        <flowNodeRef>Task_SA_CekData</flowNodeRef>
      </lane>
      <lane id="Lane_SistemExisting" name="Sistem Existing">
        <flowNodeRef>Task_SYS_TampilkanForm</flowNodeRef>
        <flowNodeRef>End_SYS</flowNodeRef>
        <flowNodeRef>Task_SYS_TambahStok</flowNodeRef>
      </lane>
      <lane id="Lane_StaffGudang" name="Staff Gudang">
        <flowNodeRef>Start_SG</flowNodeRef>
        <flowNodeRef>Task_SG_TerimaBarang</flowNodeRef>
        <flowNodeRef>Task_SG_SimpanRak</flowNodeRef>
        <flowNodeRef>Task_SG_AksesInbound</flowNodeRef>
        <flowNodeRef>Task_SG_InputKuantitas</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_SG" name="Menunggu kiriman barang dari Vendor">
      <outgoing>SF_SG00</outgoing>
      <messageEventDefinition id="MED_01" />
    </startEvent>
    <manualTask id="Task_SG_TerimaBarang" name="Menerima barang fisik &#38; mencocokkan jumlah dengan Surat Jalan">
      <incoming>SF_SG00</incoming>
      <outgoing>SF_SG01</outgoing>
    </manualTask>
    <manualTask id="Task_SG_SimpanRak" name="Menyimpan barang ke rak di gudang">
      <incoming>SF_SG01</incoming>
      <outgoing>SF_SG02</outgoing>
    </manualTask>
    <userTask id="Task_SG_AksesInbound" name="Mengakses menu Inbound di Sistem Existing">
      <incoming>SF_SG02</incoming>
      <outgoing>SF_SG03</outgoing>
    </userTask>
    <serviceTask id="Task_SYS_TampilkanForm" name="Menampilkan Form Inbound Standar">
      <incoming>SF_SG03</incoming>
      <outgoing>SF_SG04</outgoing>
    </serviceTask>
    <userTask id="Task_SG_InputKuantitas" name="Menginput total penerimaan barang (hanya kuantitas global)">
      <incoming>SF_SG04</incoming>
      <outgoing>SF_SG05</outgoing>
    </userTask>
    <userTask id="Task_SA_CekData" name="Mengecek data stok baru di sistem &#38; memperbarui Master Data Item (jika SKU baru)">
      <incoming>SF_SG06</incoming>
      <outgoing>SF_SG07</outgoing>
    </userTask>
    <sequenceFlow id="SF_SG00" sourceRef="Start_SG" targetRef="Task_SG_TerimaBarang" />
    <sequenceFlow id="SF_SG01" sourceRef="Task_SG_TerimaBarang" targetRef="Task_SG_SimpanRak" />
    <sequenceFlow id="SF_SG02" sourceRef="Task_SG_SimpanRak" targetRef="Task_SG_AksesInbound" />
    <sequenceFlow id="SF_SG03" sourceRef="Task_SG_AksesInbound" targetRef="Task_SYS_TampilkanForm" />
    <sequenceFlow id="SF_SG04" sourceRef="Task_SYS_TampilkanForm" targetRef="Task_SG_InputKuantitas" />
    <sequenceFlow id="SF_SG05" sourceRef="Task_SG_InputKuantitas" targetRef="Task_SYS_TambahStok" />
    <sequenceFlow id="SF_SG06" sourceRef="Task_SYS_TambahStok" targetRef="Task_SA_CekData" />
    <sequenceFlow id="SF_SG07" sourceRef="Task_SA_CekData" targetRef="End_SYS" />
    <endEvent id="End_SYS" name="Proses Inbound selesai">
      <incoming>SF_SG07</incoming>
    </endEvent>
    <serviceTask id="Task_SYS_TambahStok" name="Menambah stok global produk di database">
      <incoming>SF_SG05</incoming>
      <outgoing>SF_SG06</outgoing>
    </serviceTask>
  </process>
