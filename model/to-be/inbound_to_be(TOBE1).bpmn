          <dc:Bounds x="286" y="80" width="67" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1dfsm5k_di" bpmnElement="Event_1dfsm5k">
