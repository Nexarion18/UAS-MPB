<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_InboundWMS" targetNamespace="http://satglow.wms/inbound" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collaboration_Inbound">
    <bpmn:participant id="Pool_Vendor" name="Vendor" processRef="Process_Vendor" />
    <bpmn:participant id="Pool_Satglow" name="Satglow" processRef="Process_Satglow_inbound" />
    <bpmn:messageFlow id="Flow_0vz3n1t" sourceRef="Task_TerimaBarang" targetRef="StartEvent_Vendor" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Vendor" name="Vendor" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Vendor" name="Mengirimkan Surat Jalan &#38; Barang Fisik">
      <bpmn:outgoing>Flow_12x78wo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="Event_1dfsm5k">
      <bpmn:incoming>Flow_12x78wo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_12x78wo" sourceRef="StartEvent_Vendor" targetRef="Event_1dfsm5k" />
  </bpmn:process>
  <bpmn:process id="Process_Satglow_inbound" name="Proses 8 - Inbound Satglow" isExecutable="true" camunda:historyTimeToLive="30" camunda:tenantId="55555">
    <bpmn:laneSet id="LaneSet_Satglow">
      <bpmn:lane id="Lane_SistemWMS" name="Sistem WMS">
        <bpmn:flowNodeRef>Task_GenerateForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_BarangMasuk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AlokasiIDBatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SimpanDatabase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TampilkanAlertError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ValidasiField</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_StaffGudang" name="Staff Gudang">
        <bpmn:flowNodeRef>Event_0ax0b3j</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TerimaBarang</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AksesModulInbound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InputFieldMandatory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisInput</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Event_0ax0b3j" name="Mulai Proses Inbound">
      <bpmn:outgoing>Flow_0g357fd</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_TerimaBarang" name="Menerima barang fisik" camunda:candidateGroups="gudangSG">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="konfirmasiTerima" label="Ketik OK jika fisik barang dari Vendor sudah diterima:" type="string" defaultValue="OK" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0g357fd</bpmn:incoming>
      <bpmn:outgoing>Flow_1_to_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AksesModulInbound" name="Mengakses modul Inbound di Sistem WMS" camunda:candidateGroups="gudangSG">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="infoModul" label="Status" type="string" defaultValue="Klik Complete untuk membuka modul Inbound." />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1_to_2</bpmn:incoming>
      <bpmn:outgoing>Flow_2_to_GenerateForm</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_GenerateForm" name="Men-generate Form Inbound Digital">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">"https://discordapp.com/api/webhooks/1517172296018559207/o7F755573IME08LxZj5eJw_6Sz994TBxIFKkYXtzdl5vQgaKYuXuDYfINpEV2UuIzn06";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">
              <camunda:script scriptFormat="javascript">"POST";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="javascript">var pesan = "🚀 **Notifikasi WMS Satglow** 🚀\nSistem sedang men-generate Form Inbound Digital untuk staff gudang.";
JSON.stringify({ "content": pesan });</camunda:script>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2_to_GenerateForm</bpmn:incoming>
      <bpmn:outgoing>Flow_GenerateForm_to_Input</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_InputFieldMandatory" name="Input data barang" camunda:formRef="Form_InputInbound" camunda:formRefBinding="latest" camunda:candidateGroups="gudangSG">
      <bpmn:incoming>Flow_GenerateForm_to_Input</bpmn:incoming>
      <bpmn:incoming>Flow_Revis_to_Input</bpmn:incoming>
      <bpmn:outgoing>Flow_Input_to_GW</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_ValidasiField" name="Apakah semua field terisi valid?">
      <bpmn:incoming>Flow_Input_to_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_GW_Valid</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW_TidakValid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_TampilkanAlertError" name="Menampilkan alert error">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">"https://discordapp.com/api/webhooks/1517172296018559207/o7F755573IME08LxZj5eJw_6Sz994TBxIFKkYXtzdl5vQgaKYuXuDYfINpEV2UuIzn06";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">
              <camunda:script scriptFormat="javascript">"POST";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="javascript">JSON.stringify({ "content": "🛑 **[WMS INBOUND ERROR]** Input data tidak valid. Sistem mengembalikan tugas ke Staff Gudang untuk melakukan revisi!" });</camunda:script>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GW_TidakValid</bpmn:incoming>
      <bpmn:outgoing>Flow_Alert_to_Revis</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_RevisInput" name="Revisi field yang tidak valid" camunda:candidateGroups="gudangSG">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="infoError" label="Peringatan Sistem!" type="string" defaultValue="Format tidak valid! Klik Complete untuk mengulang input." />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Alert_to_Revis</bpmn:incoming>
      <bpmn:outgoing>Flow_Revis_to_Input</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_AlokasiIDBatch" name="Mengalokasikan ID Batch unik berdasarkan Tanggal Kedaluwarsa">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">"https://discordapp.com/api/webhooks/1517172296018559207/o7F755573IME08LxZj5eJw_6Sz994TBxIFKkYXtzdl5vQgaKYuXuDYfINpEV2UuIzn06";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">
              <camunda:script scriptFormat="javascript">"POST";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="javascript">JSON.stringify({ "content": "🟢 **[WMS INBOUND VALID]** Verifikasi input sukses. Sistem mengalokasikan ID Batch baru berdasarkan tanggal kedaluwarsa." });</camunda:script>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GW_Valid</bpmn:incoming>
      <bpmn:outgoing>Flow_Batch_to_DB</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SimpanDatabase" name="Menyimpan data Inbound ke Database">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">"https://discordapp.com/api/webhooks/1517172296018559207/o7F755573IME08LxZj5eJw_6Sz994TBxIFKkYXtzdl5vQgaKYuXuDYfINpEV2UuIzn06";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">
              <camunda:script scriptFormat="javascript">"POST";</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="javascript">var nama = execution.getVariable("namaBarang") || "Barang Unknown";
var qty = execution.getVariable("qtyBarang") || "0";
var pesan = "📦 **WMS Inbound Sukses:** Barang **" + nama + "** sebanyak **" + qty + " pcs** telah diverifikasi dan disimpan ke Database WMS Satglow.";
JSON.stringify({ "content": pesan });</camunda:script>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Batch_to_DB</bpmn:incoming>
      <bpmn:outgoing>Flow_DB_to_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_BarangMasuk" name="Barang berhasil masuk dengan track record per batch yang akurat">
      <bpmn:incoming>Flow_DB_to_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0g357fd" sourceRef="Event_0ax0b3j" targetRef="Task_TerimaBarang" />
    <bpmn:sequenceFlow id="Flow_1_to_2" sourceRef="Task_TerimaBarang" targetRef="Task_AksesModulInbound" />
    <bpmn:sequenceFlow id="Flow_2_to_GenerateForm" sourceRef="Task_AksesModulInbound" targetRef="Task_GenerateForm" />
    <bpmn:sequenceFlow id="Flow_GenerateForm_to_Input" sourceRef="Task_GenerateForm" targetRef="Task_InputFieldMandatory" />
    <bpmn:sequenceFlow id="Flow_Input_to_GW" sourceRef="Task_InputFieldMandatory" targetRef="GW_ValidasiField" />
    <bpmn:sequenceFlow id="Flow_GW_Valid" name="Valid" sourceRef="GW_ValidasiField" targetRef="Task_AlokasiIDBatch">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isValid == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW_TidakValid" name="Tidak Valid" sourceRef="GW_ValidasiField" targetRef="Task_TampilkanAlertError">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isValid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Alert_to_Revis" sourceRef="Task_TampilkanAlertError" targetRef="Task_RevisInput" />
    <bpmn:sequenceFlow id="Flow_Revis_to_Input" name="Kembali ke revisi" sourceRef="Task_RevisInput" targetRef="Task_InputFieldMandatory" />
    <bpmn:sequenceFlow id="Flow_Batch_to_DB" sourceRef="Task_AlokasiIDBatch" targetRef="Task_SimpanDatabase" />
    <bpmn:sequenceFlow id="Flow_DB_to_End" sourceRef="Task_SimpanDatabase" targetRef="EndEvent_BarangMasuk" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_Inbound">
      <bpmndi:BPMNShape id="Shape_Pool_Vendor" bpmnElement="Pool_Vendor" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="970" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartVendor" bpmnElement="StartEvent_Vendor">
