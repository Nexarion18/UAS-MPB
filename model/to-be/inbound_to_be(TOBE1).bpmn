        <bpmndi:BPMNLabel>
          <dc:Bounds x="768" y="636" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_GW_Invalid" bpmnElement="Flow_GW_TidakValid">
        <di:waypoint x="765" y="530" />
