      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_12x78wo_di" bpmnElement="Flow_12x78wo">
        <di:waypoint x="258" y="140" />
        <di:waypoint x="362" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Pool_Satglow" bpmnElement="Pool_Satglow" isHorizontal="true">
        <dc:Bounds x="160" y="200" width="970" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Staff" bpmnElement="Lane_StaffGudang" isHorizontal="true">
        <dc:Bounds x="190" y="200" width="940" height="240" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_WMS" bpmnElement="Lane_SistemWMS" isHorizontal="true">
        <dc:Bounds x="190" y="440" width="940" height="320" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0ax0b3j_di" bpmnElement="Event_0ax0b3j">
        <dc:Bounds x="232" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="212" y="325" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_TerimaBarang" bpmnElement="Task_TerimaBarang">
        <dc:Bounds x="310" y="270" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_AksesModul" bpmnElement="Task_AksesModulInbound">
        <dc:Bounds x="490" y="270" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GenerateForm" bpmnElement="Task_GenerateForm">
        <dc:Bounds x="490" y="490" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_InputField" bpmnElement="Task_InputFieldMandatory">
        <dc:Bounds x="670" y="260" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_Valid" bpmnElement="GW_ValidasiField" isMarkerVisible="true">
        <dc:Bounds x="715" y="505" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="749" y="553" width="82" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_AlertError" bpmnElement="Task_TampilkanAlertError">
        <dc:Bounds x="940" y="500" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_RevisInput" bpmnElement="Task_RevisInput">
        <dc:Bounds x="940" y="270" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_AlokasiBatch" bpmnElement="Task_AlokasiIDBatch">
        <dc:Bounds x="690" y="670" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_SimpanDB" bpmnElement="Task_SimpanDatabase">
        <dc:Bounds x="490" y="670" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndBarang" bpmnElement="EndEvent_BarangMasuk">
        <dc:Bounds x="322" y="632" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="297" y="675" width="88" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_0g357fd_di" bpmnElement="Flow_0g357fd">
        <di:waypoint x="268" y="300" />
        <di:waypoint x="310" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_1_2" bpmnElement="Flow_1_to_2">
        <di:waypoint x="430" y="300" />
        <di:waypoint x="490" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_2_Gen" bpmnElement="Flow_2_to_GenerateForm">
        <di:waypoint x="555" y="330" />
        <di:waypoint x="555" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gen_Input" bpmnElement="Flow_GenerateForm_to_Input">
        <di:waypoint x="620" y="520" />
