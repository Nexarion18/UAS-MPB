<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_PredictiveRestocking" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collaboration_PredictiveRestocking" name="Predictive Restocking Collaboration">
    <bpmn:participant id="Participant_Satglow" name="Internal Satglow" processRef="Process_PredictiveRestocking" />
  </bpmn:collaboration>
  <bpmn:process id="Process_PredictiveRestocking" name="Proses 4 - Predictive Restocking (Peramalan Stok Otomatis)" isExecutable="true" camunda:historyTimeToLive="30" camunda:tenantId="55555">
    <bpmn:laneSet id="LaneSet_Satglow">
      <bpmn:lane id="Lane_StaffAdmin" name="Staff Admin">
        <bpmn:flowNodeRef>Task_KirimPOSupplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_RestockSelesai</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Manager WMS">
        <bpmn:flowNodeRef>Task_ReviewDraftPO</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_KelulusanManager</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SistemWMS" name="Sistem WMS (Otomatisasi &#38; AI)">
        <bpmn:flowNodeRef>StartEvent_JadwalRestock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_ForecastingVelocity</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_CekKecukupanStok</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_StokAman</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AutoGenerateDraftPO</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PORefused</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_JadwalRestock" name="Jadwal Restock Bulanan Tiba">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="stokCukup" label="Simulasi Hasil Forecasting AI: Apakah Stok Gudang Masih Cukup?" type="boolean" defaultValue="false" />
          <camunda:formField id="jumlahRestok" label="Simulasi Jumlah yang Harus Di-restok (Hanya diisi jika stok menipis)" type="long" defaultValue="1000" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>SF_Start_to_Forecast</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_AI_ForecastingVelocity" name="Sistem Menganalisis Histori Penjualan (AI Forecasting Velocity)" camunda:expression="${true}">
      <bpmn:incoming>SF_Start_to_Forecast</bpmn:incoming>
      <bpmn:outgoing>SF_Forecast_to_GW1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_CekKecukupanStok" name="Stok Cukup?">
      <bpmn:incoming>SF_Forecast_to_GW1</bpmn:incoming>
      <bpmn:outgoing>SF_GW1_to_StokAman</bpmn:outgoing>
      <bpmn:outgoing>SF_GW1_to_DraftPO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_StokAman" name="Stok Aman">
      <bpmn:incoming>SF_GW1_to_StokAman</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_ReviewDraftPO" name="Review Draft PO oleh Manager" camunda:candidateGroups="managerSG" camunda:formRef="Form_ReviewPO" camunda:formRefBinding="latest">
  <bpmn:incoming>SF_DraftPO_to_ReviewPO</bpmn:incoming>
  <bpmn:outgoing>SF_ReviewPO_to_GW2</bpmn:outgoing>
</bpmn:userTask>
    <bpmn:userTask id="Task_KirimPOSupplier" name="Kirim PO ke Supplier" camunda:candidateGroups="adminSG">
      <bpmn:incoming>SF_GW2_to_KirimPO</bpmn:incoming>
      <bpmn:outgoing>SF_KirimPO_to_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_RestockSelesai" name="Restock Selesai">
      <bpmn:incoming>SF_KirimPO_to_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_Start_to_Forecast" sourceRef="StartEvent_JadwalRestock" targetRef="Task_AI_ForecastingVelocity" />
    <bpmn:sequenceFlow id="SF_Forecast_to_GW1" sourceRef="Task_AI_ForecastingVelocity" targetRef="GW_CekKecukupanStok" />
    <bpmn:sequenceFlow id="SF_GW1_to_StokAman" name="Stok Cukup" sourceRef="GW_CekKecukupanStok" targetRef="EndEvent_StokAman">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${stokCukup == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_GW1_to_DraftPO" name="Stok Menipis" sourceRef="GW_CekKecukupanStok" targetRef="Task_AutoGenerateDraftPO">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${stokCukup == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_DraftPO_to_ReviewPO" sourceRef="Task_AutoGenerateDraftPO" targetRef="Task_ReviewDraftPO" />
    <bpmn:sequenceFlow id="SF_ReviewPO_to_GW2" sourceRef="Task_ReviewDraftPO" targetRef="GW_KelulusanManager" />
    <bpmn:sequenceFlow id="SF_GW2_to_PORefused" name="Ditolak" sourceRef="GW_KelulusanManager" targetRef="EndEvent_PORefused">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerPODecision == 'tolak'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_GW2_to_KirimPO" name="Disetujui" sourceRef="GW_KelulusanManager" targetRef="Task_KirimPOSupplier">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${managerPODecision == 'setuju'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_KirimPO_to_End" sourceRef="Task_KirimPOSupplier" targetRef="EndEvent_RestockSelesai" />
    <bpmn:serviceTask id="Task_AutoGenerateDraftPO" name="Sistem Membuat Draf Purchase Order Otomatis" camunda:expression="${true}">
      <bpmn:incoming>SF_GW1_to_DraftPO</bpmn:incoming>
      <bpmn:outgoing>SF_DraftPO_to_ReviewPO</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_KelulusanManager" name="Disetujui Manager?">
      <bpmn:incoming>SF_ReviewPO_to_GW2</bpmn:incoming>
      <bpmn:outgoing>SF_GW2_to_PORefused</bpmn:outgoing>
      <bpmn:outgoing>SF_GW2_to_KirimPO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_PORefused" name="PO Ditolak">
      <bpmn:incoming>SF_GW2_to_PORefused</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_PredictiveRestocking">
    <bpmndi:BPMNPlane id="BPMNPlane_PredictiveRestocking" bpmnElement="Collaboration_PredictiveRestocking">
      <bpmndi:BPMNShape id="Participant_Satglow_di" bpmnElement="Participant_Satglow" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="1000" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SistemWMS_di" bpmnElement="Lane_SistemWMS" isHorizontal="true">
        <dc:Bounds x="150" y="80" width="970" height="240" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="150" y="320" width="970" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_StaffAdmin_di" bpmnElement="Lane_StaffAdmin" isHorizontal="true">
        <dc:Bounds x="150" y="480" width="970" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_JadwalRestock_di" bpmnElement="StartEvent_JadwalRestock">
        <dc:Bounds x="200" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="180" y="265" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_ForecastingVelocity_di" bpmnElement="Task_AI_ForecastingVelocity">
        <dc:Bounds x="290" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_CekKecukupanStok_di" bpmnElement="GW_CekKecukupanStok" isMarkerVisible="true">
        <dc:Bounds x="445" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="439" y="272" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_StokAman_di" bpmnElement="EndEvent_StokAman">
        <dc:Bounds x="452" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="444" y="145" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewDraftPO_di" bpmnElement="Task_ReviewDraftPO">
        <dc:Bounds x="550" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_KirimPOSupplier_di" bpmnElement="Task_KirimPOSupplier">
        <dc:Bounds x="810" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RestockSelesai_di" bpmnElement="EndEvent_RestockSelesai">
        <dc:Bounds x="972" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="951" y="585" width="79" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AutoGenerateDraftPO_di" bpmnElement="Task_AutoGenerateDraftPO">
        <dc:Bounds x="610" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_KelulusanManager_di" bpmnElement="GW_KelulusanManager" isMarkerVisible="true">
        <dc:Bounds x="755" y="375" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="815" y="386" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PORefused_di" bpmnElement="EndEvent_PORefused">
        <dc:Bounds x="762" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="753" y="243" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="SF_Start_to_Forecast_di" bpmnElement="SF_Start_to_Forecast">
        <di:waypoint x="236" y="240" />
        <di:waypoint x="290" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_Forecast_to_GW1_di" bpmnElement="SF_Forecast_to_GW1">
        <di:waypoint x="390" y="240" />
        <di:waypoint x="445" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_GW1_to_StokAman_di" bpmnElement="SF_GW1_to_StokAman">
        <di:waypoint x="470" y="215" />
        <di:waypoint x="470" y="138" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="476" y="174" width="57" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_GW1_to_DraftPO_di" bpmnElement="SF_GW1_to_DraftPO">
        <di:waypoint x="495" y="240" />
        <di:waypoint x="610" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="524" y="222" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_DraftPO_to_ReviewPO_di" bpmnElement="SF_DraftPO_to_ReviewPO">
        <di:waypoint x="660" y="280" />
        <di:waypoint x="660" y="320" />
        <di:waypoint x="600" y="320" />
        <di:waypoint x="600" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_ReviewPO_to_GW2_di" bpmnElement="SF_ReviewPO_to_GW2">
        <di:waypoint x="650" y="400" />
        <di:waypoint x="755" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_GW2_to_PORefused_di" bpmnElement="SF_GW2_to_PORefused">
        <di:waypoint x="780" y="375" />
        <di:waypoint x="780" y="298" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="784" y="334" width="35" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_GW2_to_KirimPO_di" bpmnElement="SF_GW2_to_KirimPO">
        <di:waypoint x="780" y="425" />
        <di:waypoint x="780" y="560" />
        <di:waypoint x="810" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="789" y="490" width="43" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_KirimPO_to_End_di" bpmnElement="SF_KirimPO_to_End">
        <di:waypoint x="910" y="560" />
        <di:waypoint x="972" y="560" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
